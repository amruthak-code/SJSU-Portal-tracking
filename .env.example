# ─────────────────────────────────────────────────────────────
# SJSU Course Seat Tracker — environment variables
# Copy this file to `.env` (for the scraper, local runs) and to
# `web/.env.local` (for the Next.js app). NEVER commit the filled-in files.
# In GitHub, set these as repository Secrets (Settings → Secrets → Actions).
# ─────────────────────────────────────────────────────────────

# --- Gmail SMTP (used by the scraper to send seat-available alerts) ---
# GMAIL_USER:         your full Gmail address, e.g. you@gmail.com
# GMAIL_APP_PASSWORD: a 16-char Google "App Password" (NOT your login password).
#   Create at: https://myaccount.google.com/apppasswords  (requires 2FA enabled)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Where alerts are sent (defaults to GMAIL_USER if left blank)
ALERT_TO=

# --- Anthropic / Claude (used by the Next.js app: Smart Search + Degree Audit) ---
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# NOTE: We use SJSU's PUBLIC class search (no login), so the
# SJSU_USER / SJSU_PASS variables from the original spec are NOT needed.
# ─────────────────────────────────────────────────────────────
