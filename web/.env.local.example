# Copy to web/.env.local for local development of the Next.js app.
# Only the Gemini key is needed by the web app (Smart Search + Degree Audit).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override where courses.json / status_log.json live.
# Defaults to the repo root (one level above web/).
# DATA_DIR=..
