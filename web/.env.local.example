# Copy to web/.env.local for local development of the Next.js app.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — NEVER expose to the browser. Used by internal scraper API.
SUPABASE_SERVICE_ROLE_KEY=

# --- Internal API auth (shared secret the scraper sends) ---
# Generate one: `openssl rand -hex 32`
CRON_SECRET=

# --- Gemini (Smart Search + Degree Audit) ---
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
